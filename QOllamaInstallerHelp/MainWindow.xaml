<Window x:Class="QOllamaInstallerHelp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QOllamaInstallerHelp"
        mc:Ignorable="d"
        xmlns:views="clr-namespace:QOllamaInstallerHelp.Views"
        xmlns:cps="clr-namespace:QOllamaInstallerHelp.Views.CPanels"
        Title="Ollama工具" Height="450" Width="800">
    <Grid>
        <cps:PagePanel x:Name="PAGE_PANEL">
            <Border>
                <views:InstallerSelectPage/>
            </Border>
            <Border>
                <views:RegistryEditPage/>
            </Border>
        </cps:PagePanel>
        <Button Content="注册表 / 安装" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="25" Padding="5" Name="BT_NextPage" Click="BT_NextPage_Click"/>
    </Grid>
</Window>
