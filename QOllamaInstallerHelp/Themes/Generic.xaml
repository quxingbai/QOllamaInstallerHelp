<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="clr-namespace:QOllamaInstallerHelp.Utils"
    xmlns:local="clr-namespace:QOllamaInstallerHelp.Views.CControls">

    <utils:BoolVisiblityConverter x:Name="CONVERTER_BoolVisibilityConverter" x:Key="CONVERTER_BoolVisibilityConverter"/>


    <Style TargetType="{x:Type local:PathSelectTextBox}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PathSelectTextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="5,0" Margin="10,0" Visibility="{TemplateBinding IsSuccessInput,Converter={StaticResource CONVERTER_BoolVisibilityConverter},ConverterParameter=Rever}">
                                <Border.Background>
                                    <VisualBrush Stretch="UniformToFill">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="×" FontWeight="Bold" Foreground="Red"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.Background>
                            </Border>
                            <ScrollViewer Grid.Column="1" FocusVisualStyle="{x:Null}" x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            <Border Grid.Column="2">
                                <Button Content="..." Padding="5,0" Command="{Binding PathSelectCommand,RelativeSource={RelativeSource Mode=TemplatedParent}}" CommandParameter="1"/>
                            </Border>
                        </Grid>
                        
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
