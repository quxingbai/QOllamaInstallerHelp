<UserControl x:Class="QOllamaInstallerHelp.Views.InstallerSelectPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QOllamaInstallerHelp.Views"
             mc:Ignorable="d" 
             xmlns:cc="clr-namespace:QOllamaInstallerHelp.Views.CControls"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="DimGray"/>
            <Setter Property="Margin" Value="0,7.5"/>
        </Style>
        <Style TargetType="cc:PathSelectTextBox">
            <Setter Property="Foreground" Value="black"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Padding="15">
            <Grid>
                <StackPanel>
                    <GroupBox Header="下载Ollama" ToolTip="下载过就跳过">
                        <Border Padding="5">
                            <TextBlock Foreground="Black">
                                <Run Text="官方网站："/>
                                <Hyperlink Command="{Binding COMMAND_OpenOllamaUrlCommand}" CommandParameter="https://ollama.com/download">
                                    <Run Text="https://ollama.com/download"/>
                                </Hyperlink>
                            </TextBlock>
                        </Border>
                    </GroupBox>
                    <GroupBox Header="安装文件" ToolTip="就是官网下载的那个exe文件地址 OllamaSetup.exe">
                        <Border Padding="5">
                            <cc:PathSelectTextBox Text="{Binding OllamaSetupExePath}"/>
                        </Border>
                    </GroupBox>
                    <GroupBox Header="安装到哪里" ToolTip="默认是在C盘，但也可以修改">
                        <Border Padding="5">
                            <StackPanel>
                                <cc:PathSelectTextBox Text="{Binding OllamaInstallPath}" PathType="Fold"/>
                            </StackPanel>
                        </Border>
                    </GroupBox>
                    <GroupBox Header="其他（需要管理员权限）" ToolTip="这里需要管理员权限，不安装会出现一些问题">
                        <Border Padding="5">
                            <WrapPanel>
                                <ToggleButton IsChecked="{Binding IsWriteRegistry}" Content="写入注册表"/>
                            </WrapPanel>
                        </Border>
                    </GroupBox>
                </StackPanel>
                <Button Content="安装" FontSize="15" Padding="10" Command="{Binding COMMAND_TryInstall}" Margin="0,15" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
