<UserControl x:Class="QOllamaInstallerHelp.Views.RegistryEditPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QOllamaInstallerHelp.Views"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:QOllamaInstallerHelp.ViewModels"
             xmlns:cc="clr-namespace:QOllamaInstallerHelp.Views.CControls"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border>
                <Border Padding="5" Background="Transparent" CornerRadius="5" Margin="0,25,0,0">
                    <!--<TextBox FontSize="20" Background="Transparent" BorderThickness="0"/>-->
                    <cc:LabelTextBox FontSize="20" EmptyTextDisplay="关键字匹配" Text="{Binding QueryBoxText,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                </Border>
            </Border>
            <Border Grid.Row="1">
                <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemsSource="{Binding RegistryItems}" Background="Transparent" BorderThickness="0" Margin="15">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,10"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Padding="5" Cursor="Hand" Background="{TemplateBinding Background}" BorderThickness="5,0,0,0" BorderBrush="#262626">
                                            <Grid>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock  Name="TEXT_NAME">
                                                        <Run Text="{Binding Name,Mode=OneWay}"  FontWeight="Bold" FontSize="20"/>
                                                        <Run Text="" Name="TEXT_NAME_CREATED"/>
                                                    </TextBlock>
                                                    <Border Grid.Row="1">
                                                        <StackPanel Margin="5">
                                                            <TextBlock Text="{Binding ToolTip}" TextWrapping="Wrap"/>
                                                            <Border Margin="5">
                                                                <TextBlock>
                                                                    <Run Text="·"/>
                                                                    <Run Text="默认值"/>
                                                                    <Run Text="{Binding DefaultValue}"/>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5" Visibility="Collapsed" Name="BD_EditButtons">
                                                    <WrapPanel>
                                                        <Button Content="写入注册表" Padding="5" Command="{Binding ShowRegistryEditCommand}"/>
                                                    </WrapPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="WhiteSmoke"/>
                                                <Setter Property="Visibility" Value="Visible" TargetName="BD_EditButtons"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="WhiteSmoke"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsVisibile}" Value="Collapsed">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsVisibile}" Value="Visible">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInLocalRegistry}" Value="True">
                                                <Setter Property="Foreground" Value="DodgerBlue" TargetName="TEXT_NAME"/>
                                                <Setter Property="Text" Value="  已创建" TargetName="TEXT_NAME_CREATED"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Grid>
        <Border>
            <ContentControl Content="{Binding RegistryItemEditPageViewModel}" Visibility="{Binding RegistryItemEditPageVisibility}">
                <ContentControl.Resources>
                    <!--<DataTemplate DataType="vm:RegistryItemEditPageViewModel">-->
                    <DataTemplate DataType="{x:Type vm:RegistryItemEditPageViewModel}">
                        <local:RegistryItemEditPage  DataContext="{Binding}"/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Border>
    </Grid>
</UserControl>
