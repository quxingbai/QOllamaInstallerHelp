<UserControl x:Class="QOllamaInstallerHelp.Views.RegistryItemEditPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QOllamaInstallerHelp.Views"
             mc:Ignorable="d" 
            xmlns:cc="clr-namespace:QOllamaInstallerHelp.Views.CControls"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid  VerticalAlignment="Center" Width="500">
            <Border Background="WhiteSmoke" CornerRadius="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
            </Border>
            <Border CornerRadius="5" Background="WhiteSmoke"  Padding="15" >
                <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="20" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Left" Margin="15,4"/>
                    <TextBlock Text="{Binding ToolTip}" TextWrapping="Wrap" Margin="15,5" Foreground="DimGray"/>
                    <Border Padding="5" Margin="5">
                        <cc:LabelTextBox EmptyTextDisplay="{Binding DefaultValue}" TextWrapping="Wrap" Text="{Binding Value}" FontSize="18" LabelTitle="注册表值"/>
                    </Border>
                    <UniformGrid Rows="1" Columns="2" TextBlock.FontSize="15">
                        <UniformGrid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="Margin" Value="5"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </UniformGrid.Resources>
                        <Border>
                            <Button Content="确认修改" Padding="5" Command="{Binding COMMAND_UpdateRegistry}"/>
                        </Border>
                        <Border>
                            <Button Content="取消" Padding="5" Command="{Binding COMMAND_Hidden}"/>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
